<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:orientation="vertical"
    tools:context=".ResultQuiz">
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/gutgemacht"
        android:text="Gut gemacht!"
        android:textColor="#F7C815"
        android:textSize="46sp"
        android:textStyle="bold"
        android:shadowColor="@color/black"
        android:shadowDx="8"
        android:shadowDy="4"
        android:shadowRadius="1"
        android:layout_marginTop="11dp"
        android:layout_marginStart="56dp"
        android:layout_marginEnd="56dp"
        />
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/einfachtext"
        android:layout_below="@id/gutgemacht"
        android:text="Jede noch so kleine Handlung bringt uns unserem Ziel näher als das perfekte Nichtstun!"
        android:textColor="#394a4d"
        android:textSize="16sp"
        android:gravity="center"
        android:layout_marginTop="6dp"
        android:layout_marginStart="56dp"
        android:layout_marginEnd="56dp"
        />
    <ImageView
    android:id="@+id/congratulationIcon"
    android:layout_below="@id/einfachtext"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="66dp"
    android:layout_marginTop="1dp"
    android:layout_marginEnd="66dp"
    android:adjustViewBounds="true"
    android:src="@drawable/educationman"
    />
    <TextView
        android:id="@+id/successTextView"
        android:layout_below="@+id/congratulationIcon"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:layout_marginStart="70dp"
        android:layout_marginEnd="70dp"
        android:gravity="center"
        android:text="Das Ergebnis:"
        android:textColor="#F7C815"
        android:textSize="33sp"
        android:textStyle="bold"
        android:shadowColor="@color/black"
        android:shadowDx="5"
        android:shadowDy="3"
        android:shadowRadius="2"
        />
    <LinearLayout
        android:layout_below="@+id/successTextView"
        android:layout_width="wrap_content"
        android:layout_height="110dp"
        android:orientation="horizontal"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="16dp">

        <TextView
            android:id="@+id/correctAnswers"
            android:layout_width="160dp"
            android:layout_height="110dp"
            android:text="Rechts :"
            android:textColor="@color/white"
            android:textSize="23sp"
            android:layout_marginEnd="15dp"
            android:gravity="center"
            android:background="@drawable/round_back_green_1"
            android:padding="9dp"
            />

        <TextView
            android:id="@+id/incorrectAnswers"
            android:layout_width="160dp"
            android:layout_height="110dp"
            android:text="Falsch :"
            android:layout_marginStart="20dp"
            android:textColor="@color/white"
            android:gravity="center"
            android:background="@drawable/round_back_pink_1"
            android:textSize="23sp"
            android:padding="9dp"
            />

    </LinearLayout>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/startNewQuizBtn"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_alignParentBottom="true"
        android:layout_marginStart="75dp"
        android:layout_marginEnd="75dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="60dp"
        android:background="@drawable/round_back_yellow_3"
        android:text="neue Aufgabe"
        android:textColor="#FFFFFF"
        android:textSize="19sp"/>

</RelativeLayout>
