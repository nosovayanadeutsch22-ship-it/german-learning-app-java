<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEF6F6"
    android:orientation="vertical"
    tools:context=".QuizActivity">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:background="#7AA7D2"
        >

        <ImageView
            android:id="@+id/backBtn"
            android:layout_width="wrap_content"
            android:layout_height="64dp"
            android:src="@drawable/home"
            android:layout_marginTop="3dp"
            android:layout_marginStart="13dp"
            android:layout_marginEnd="6dp"
            android:adjustViewBounds="true" />
        <TextView
            android:id="@+id/selectedTopicName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:shadowColor="#583E26"
            android:layout_marginTop="23dp"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="3"
            android:text="Selected Topic Name "
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

    </RelativeLayout>
    <TextView
        android:id="@+id/question"
        android:layout_width="match_parent"
        android:layout_height="169dp"
        android:layout_marginStart="66dp"
        android:layout_marginEnd="66dp"
        android:background="@drawable/round_back_lightblau"
        android:gravity="center"
        android:layout_marginTop="29dp"
        android:minHeight="240dp"
        android:text="Questions here..."
        android:textSize="23sp"
        android:textStyle="italic"
        android:textColor="#394a4d"
        android:padding="25dp"
        />
    <TextView
        android:id="@+id/questions"
        android:layout_width="wrap_content"
        android:layout_height="43dp"
        android:layout_gravity="center"
        android:gravity="center"
        android:layout_marginTop="19dp"
        android:elevation="1dp"
        android:paddingStart="15dp"
        android:paddingEnd="15dp"
        android:text="1/10"
        android:textSize="19sp"
        android:textColor="#394a4d"
        android:background="@drawable/round_back_3_hellgrey"
        android:padding="6dp"
        />
    <TextView
        android:id="@+id/textZumQuiz"
        android:layout_width="wrap_content"
        android:layout_height="50dp"
        android:layout_gravity="center"
        android:gravity="center"
        android:layout_marginTop="16dp"
        android:elevation="1dp"
        android:paddingStart="66dp"
        android:paddingEnd="66dp"
        android:text="Welche Präposition passt zu diesem Verb?"
        android:textSize="18sp"
        android:textColor="#394a4d"
        />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:background="#EEF6F6"
        android:layout_marginTop="9dp">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/option1"
            android:layout_width="150dp"
            android:layout_height="90dp"
            android:layout_marginStart="35dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/round_back_white_3"
            android:gravity="center"
            android:text="option1"
            android:textSize="19sp"
            android:textColor="#394a4d"
            />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/option2"
            android:layout_width="150dp"
            android:layout_height="90dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="35dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/round_back_white_3"
            android:text="option2"
            android:gravity="center"
            android:textSize="19sp"
            android:textColor="#394a4d"
            android:layout_alignParentEnd="true"
            />
    </RelativeLayout>
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:background="#EEF6F6"
        android:layout_marginTop="19dp">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/option3"
            android:layout_width="150dp"
            android:layout_height="90dp"
            android:layout_marginStart="35dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/round_back_white_3"
            android:gravity="center"
            android:text="option3"
            android:textSize="19sp"
            android:textColor="#394a4d"
            />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/option4"
            android:layout_width="150dp"
            android:layout_height="90dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="35dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/round_back_white_3"
            android:text="option4"
            android:gravity="center"
            android:textSize="19sp"
            android:textColor="#394a4d"
            android:layout_alignParentEnd="true"
            />
    </RelativeLayout>
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/nextBtn"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_alignParentBottom="true"
        android:layout_marginStart="75dp"
        android:layout_marginEnd="75dp"
        android:layout_marginTop="36dp"
        android:layout_marginBottom="65dp"
        android:background="@drawable/round_back_yellow_3"
        android:text="weiter"
        android:textSize="18sp"
        android:textColor="#FFFFFF"
        />

</LinearLayout>
