<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white"
    tools:context=".MainActivity">

    <ImageView
        android:id="@+id/welcome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="33dp"
        android:layout_marginStart="69dp"
        android:layout_marginEnd="69dp"
        android:adjustViewBounds="true"
        android:src="@drawable/text"/>
    
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/perechen"
        android:layout_below="@id/welcome"
        android:text="Verben, Nomen und Adjektive "
        android:textSize="19sp"
        android:layout_marginTop="16dp"
        android:layout_marginStart="79dp"
        android:layout_marginEnd="59dp"
        android:textColor="@color/black"
        />
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/textpraeposition"
        android:layout_below="@id/perechen"
        android:text="Präpositionen"
        android:textColor="#F7C815"
        android:textSize="39sp"
        android:textStyle="bold"
        android:shadowColor="@color/black"
        android:shadowDx="8"
        android:shadowDy="4"
        android:shadowRadius="1"
        android:layout_marginTop="16dp"
        android:layout_marginStart="79dp"
        android:layout_marginEnd="66dp"
        />
    <ImageView
        android:id="@+id/imagesince"
        android:layout_below="@id/textpraeposition"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="39dp"
        android:layout_marginStart="9dp"
        android:layout_marginEnd="9dp"
        android:adjustViewBounds="true"
        android:src="@drawable/imagesince"/>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/startQuizBtn"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_alignParentBottom="true"
        android:layout_marginStart="75dp"
        android:layout_marginEnd="75dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="65dp"
        android:background="@drawable/round_back_yellow_3"
        android:text="Start"
        android:textColor="#FFFFFF"
        android:textSize="19sp" />


</RelativeLayout>
